# Git Haiku backend — Phala (dstack) deploy env.
#
# These values are passed to `phala deploy -e .env.prod`, which ENCRYPTS them
# client-side before transmission. NEVER commit a real .env.prod and NEVER bake
# secrets into the image or docker-compose.phala.yml.
#
# Copy to .env.prod and fill in real values for a deploy.

# --- image (ghcr) ---------------------------------------------------------
GITHAIKU_BACKEND_IMAGE=ghcr.io/tinycloudlabs/githaiku-backend:latest
GITHAIKU_INGRESS_IMAGE=ghcr.io/tinycloudlabs/githaiku-backend:ingress-latest

# --- backend runtime ------------------------------------------------------
# The TEE node host the backend signs into + reads delegated secrets from.
GITHAIKU_NODE_HOST=https://tee.node.tinycloud.xyz
# Public URL of this backend (binds the haiku proof's attestation_url).
GITHAIKU_PUBLIC_URL=https://api.githaiku.com
# Comma-separated frontend origins allowed to call browser endpoints.
GITHAIKU_ALLOWED_ORIGINS=https://githaiku.com,https://www.githaiku.com

# --- RedPill confidential LLM (the real haiku generator) ------------------
# If unset, the backend falls back to the deterministic template generator.
REDPILL_API_KEY=
REDPILL_BASE_URL=https://api.redpill.ai/v1
REDPILL_MODEL=phala/deepseek-v4-flash

# --- rate limiting --------------------------------------------------------
GITHAIKU_HAIKU_RATE_MAX=20
GITHAIKU_HAIKU_RATE_WINDOW=1 minute

# --- dstack-ingress (TLS + DNS via Cloudflare) ----------------------------
PHALA_INGRESS_DOMAIN=api.githaiku.com
CLOUDFLARE_API_TOKEN=
PHALA_GATEWAY_CNAME=
CERTBOT_EMAIL=
