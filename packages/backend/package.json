{
  "name": "@githaiku/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --external:@fastify/cors --external:@phala/dstack-sdk --external:@tinycloud/node-sdk --external:@tinycloud/server --external:fastify --external:viem",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:live": "tsx test/live-delegated-secrets.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@phala/dstack-sdk": "0.5.8",
    "@tinycloud/node-sdk": "2.4.0-beta.19",
    "@tinycloud/server": "github:TinyCloudLabs/js-sdk#81269b3fef874e476384cd29b4b50c2cc06db5d0&path:/packages/server",
    "fastify": "^5.1.0",
    "siwe": "^2.3.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@githaiku/shared": "workspace:*",
    "esbuild": "0.21.5",
    "tsx": "^4.19.2"
  }
}
