{
  "name": "@githaiku/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --external:@fastify/cors --external:@phala/dstack-sdk --external:@tinycloud/cli --external:@tinycloud/node-sdk --external:fastify --external:viem",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:live": "tsx test/live-delegated-secrets.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@phala/dstack-sdk": "0.5.8",
    "@tinycloud/cli": "0.7.0-beta.1",
    "@tinycloud/node-sdk": "2.3.1-beta.0",
    "fastify": "^5.1.0",
    "jose": "^5.0.0",
    "siwe": "^2.3.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@githaiku/shared": "workspace:*",
    "esbuild": "0.21.5",
    "tsx": "^4.19.2"
  }
}
