{
  "name": "git-haiku",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c green,cyan \"pnpm --filter @githaiku/backend dev\" \"pnpm --filter @githaiku/frontend dev\"",
    "seed": "pnpm --filter @githaiku/backend seed",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}

